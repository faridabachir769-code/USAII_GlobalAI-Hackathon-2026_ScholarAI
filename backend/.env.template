# ==========================================
# ScholarAi Configuration Environment Variables
# ==========================================

# 1. Local LLM
LOCAL_LLM_URL=http://localhost:12434/engines/v1
LOCAL_LLM_MODEL=qwen2.5:7B-Q4_0

# 2. Database URL - Supabase PostgreSQL with pgvector
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# 3. Supabase Config (for pgvector)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your_supabase_anon_key_here

# 4. Redis Cache Config (Optional, defaults to in-memory dict)
REDIS_URL=

# 5. HuggingFace Token (required to download gte-small model)
HF_TOKEN=your_hf_token_here

# 6. Embedding Model Config
EMBEDDING_DIM=384
EMBEDDING_MODEL=Supabase/gte-small
